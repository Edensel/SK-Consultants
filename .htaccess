# SK Consultants Security Configuration
# This file implements comprehensive security headers and protections

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Enforce HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Remove server signature
    Header always unset X-Powered-By
    Header always unset X-AspNet-Version
</IfModule>

# Security Headers
<IfModule mod_headers.c>
    # Strict-Transport-Security (HSTS)
    # Forces HTTPS for 1 year and includes subdomains
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    
    # Content-Security-Policy (CSP)
    # Prevents XSS attacks by controlling resource loading
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://fonts.googleapis.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://*.supabase.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
    
    # X-Content-Type-Options
    # Prevents MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # X-Frame-Options
    # Prevents clickjacking attacks
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # X-XSS-Protection
    # Legacy XSS protection for older browsers
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer-Policy
    # Controls how much referrer information is shared
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions-Policy (previously Feature-Policy)
    # Controls browser features and APIs
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
    
    # Remove X-Frame-Options conflicts
    Header unset X-Frame-Options
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Cache Control for security
    Header set Cache-Control "public, max-age=3600, must-revalidate"
</IfModule>

# Disable directory browsing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Deny access to sensitive files
<FilesMatch "\.(env|json|xml|log|sql|sqlite|db)$">
    Deny from all
</FilesMatch>

# Protect .htaccess itself
<Files .htaccess>
    Deny from all
</Files>

# Protect PHP files (if any)
<FilesMatch "\.php$">
    Deny from all
</FilesMatch>

# Enable GZIP compression for performance and security
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
</IfModule>

# Set proper content types
<IfModule mod_mime.c>
    AddType text/html .html
    AddType text/css .css
    AddType text/javascript .js
    AddType application/json .json
    AddEncoding gzip .gz
</IfModule>

# Protect against common attacks
<IfModule mod_rewrite.c>
    # Block SQL injection attempts
    RewriteRule "(\"|'|(--)|(%23))" - [F]
    
    # Block XSS attempts
    RewriteRule "(<|%3C).*script.*(/|%2F)(>|%3E)" - [NC,F]
    
    # Block directory traversal
    RewriteRule "\.\./" - [F]
    
    # Block access to backup files
    RewriteRule "\.(bak|backup|old|tmp)$" - [F]
</IfModule>
