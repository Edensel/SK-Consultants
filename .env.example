# SK Consultants - Environment Configuration Template
# 
# IMPORTANT: Never commit this file to version control!
# Copy this to .env and fill in actual values
# This file should be in the server's environment variables, NOT in the web root
#
# For Apache + PHP: Set in php.ini or .user.ini
# For Node.js: Load from .env via dotenv package
# For Docker: Pass as environment variables
# For Apache + Static: Configure in web server headers

# ============================================
# SUPABASE CONFIGURATION
# ============================================

# Your Supabase Project URL
# Example: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Anon Key (public, but restricted by RLS)
# Get from: https://app.supabase.com/project/_/settings/api
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Supabase Service Role Key (private, KEEP SECRET)
# Get from: https://app.supabase.com/project/_/settings/api
# NEVER expose this in frontend code
SUPABASE_SERVICE_KEY=your_service_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Supabase Database Connection String (if needed)
DATABASE_URL=postgresql://user:password@host:5432/database

# ============================================
# SECURITY CONFIGURATION
# ============================================

# Session secret for CSRF tokens and session management
SESSION_SECRET=generate_random_strong_string_here

# API rate limiting per IP per hour
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=3600000

# Maximum message length (characters)
MAX_MESSAGE_LENGTH=5000

# Maximum name length (characters)
MAX_NAME_LENGTH=100

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Email service for form submissions notification
SMTP_HOST=mail.skconsultants.global
SMTP_PORT=587
SMTP_USER=noreply@skconsultants.global
SMTP_PASS=email_password_here
SMTP_FROM=noreply@skconsultants.global

# Contact email for form submissions
CONTACT_EMAIL=info@skconsultants.global

# ============================================
# DOMAIN & SECURITY
# ============================================

# Your website domain
DOMAIN=skconsultants.global
SITE_URL=https://skconsultants.global

# Enable HTTPS (should always be true in production)
HTTPS_ENABLED=true

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://skconsultants.global,https://www.skconsultants.global

# ============================================
# LOGGING & MONITORING
# ============================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable security logging
SECURITY_LOGGING=true

# Enable form submission logging
FORM_SUBMISSION_LOGGING=true

# ============================================
# FEATURE FLAGS
# ============================================

# Enable contact form submissions
CONTACT_FORM_ENABLED=true

# Enable analytics
ANALYTICS_ENABLED=true

# Enable cookie consent banner
COOKIE_CONSENT_ENABLED=true

# ============================================
# THIRD-PARTY INTEGRATIONS
# ============================================

# Google Analytics ID (if using)
GOOGLE_ANALYTICS_ID=

# Cloudflare Account (if using as CDN)
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# ============================================
# ADMIN CONFIGURATION (Future)
# ============================================

# Admin panel settings
ADMIN_PATH=/admin
ADMIN_PANEL_ENABLED=false

# ============================================
# INSTRUCTIONS FOR DEPLOYMENT
# ============================================

# APACHE + .htaccess:
# 1. Create .env file outside web root
# 2. Use SetEnv in .htaccess: SetEnv SUPABASE_URL "your_url"
# 3. Access via $_SERVER['SUPABASE_URL'] in PHP
# 4. For static HTML/JS, use environment variable substitution during build

# NGINX:
# 1. Set environment variables in /etc/nginx/nginx.conf or systemd unit
# 2. Use nginx-lua or similar to inject values into JavaScript
# 3. Do NOT include sensitive values in deployed JavaScript

# DOCKER:
# 1. Pass as docker run -e SUPABASE_URL="..." 
# 2. Or use docker-compose.yml environment section
# 3. Values injected at runtime, not build time

# GITHUB PAGES / STATIC HOSTING:
# 1. Use GitHub Secrets for sensitive values
# 2. Build script reads secrets and generates config files
# 3. Only non-sensitive values committed to repository

# ============================================
# SECURITY BEST PRACTICES
# ============================================

# DO:
# ✓ Use strong, random values for all secrets
# ✓ Rotate secrets periodically
# ✓ Use different values for dev/staging/production
# ✓ Store securely in environment, not in files
# ✓ Limit access to who can read these variables
# ✓ Monitor who accesses these values
# ✓ Use a secrets management system for production
# ✓ Log all access to sensitive configuration

# DON'T:
# ✗ Commit .env file to version control
# ✗ Share secrets via email or messaging
# ✗ Use weak or simple values
# ✗ Use same secrets across environments
# ✗ Print secrets in logs
# ✗ Expose secrets in error messages
# ✗ Use production secrets in development
# ✗ Give unnecessary access to configuration

# ============================================
# GENERATION HELPERS
# ============================================

# Generate random secret (Linux/Mac):
# openssl rand -base64 32

# Generate random secret (Windows PowerShell):
# [Convert]::ToBase64String([System.Random]::new().NextBytes(32))

# Test .env loading:
# echo $SUPABASE_URL

# ============================================
# VERIFICATION CHECKLIST
# ============================================

# Before deploying:
# [ ] All required variables are set
# [ ] No secrets are in version control
# [ ] Permissions are restricted (600 or similar)
# [ ] Values are correct for the environment
# [ ] HTTPS is enabled
# [ ] CORS origins are correct
# [ ] Database connection works
# [ ] Email configuration tested
# [ ] Error handling covers missing variables
# [ ] Monitoring/logging is configured
# [ ] Backup of secrets exists (secure location)
# [ ] Team has access to needed values only

